require: slotfilling/slotFilling.sc
    module = sys.zb-common

theme: /

    state: hello
        q!: $regex</start>
        q!: * (привет|здравствуй|здравствуйте|hello|хай|приветствую|доброе утро|добрый день|добрый вечер) *
        a: Привет! Я бот-помощник. Могу рассказать о погоде и подсказать курс валют. Что интересует?

    state: weather
        q!: * (~погода|~прогноз|~температура|~дождь|~снег|~ветер|~солнце|тепло|холодно|за окном|на улице|weather) *
        a: Сегодня переменная облачность, +15°C, без осадков. Хороший день!

    state: currency
        q!: * (~курс|~валюта|~доллар|~евро|~рубль|~обмен|~стоить|exchange|currency|usd|eur) *
        a: Курс на сегодня: доллар — 90 ₽, евро — 100 ₽.

    state: NoMatch
        event!: noMatch
        a: Извините, не понял запрос. Я умею про погоду и курсы валют — спросите про это.